{
  "buildCommand": "cd backend && npm install",
  "env": {
    "PLUGGY_CLIENT_ID": "@pluggy_client_id",
    "PLUGGY_CLIENT_SECRET": "@pluggy_client_secret"
  },
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/backend/index.js"
    },
    {
      "src": "/(.*)",
      "dest": "/backend/index.js"
    }
  ]
}
